# ─────────────────────────────────────────────────────────
# Saloni's Daily Digest — Environment Variables
# Copy this file to .env and fill in your secrets.
# ─────────────────────────────────────────────────────────

# Gemini API key — get yours free at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail address you're sending FROM (must have 2FA enabled)
GMAIL_USER=xxxxx.xxxx@gmail.com

# Gmail App Password (16 chars, no spaces)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Email address to receive the daily summary
RECIPIENT_EMAIL=xxxx.xxxx@gmail.com
